# C HTTP server example.
#
# "creo" builds a static binary using $CC and $CFLAGS.
# "creo image" packages it into an OCI image tarball at build/image.tar
# with Alpine as the base image (needed for libc).

build: c

image: oci
    require=build
    tag=latest
    from=alpine:latest
