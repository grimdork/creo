# Build a container image using creo's built-in OCI builder.
#
# The "oci" language mode doesn't compile — it packages an existing binary
# into an OCI image.  Use require= to depend on a build target; the
# image target will trigger a build of its dependency if needed.
# The binary path is injected as $OUTPUT_<target>.
#
# Properties: repo= (registry), tag=, tarball= (write .tar), appdir=
# (default /app), ociuser= / ocipass= (basic auth).
#
# Extra files are picked up from manifest.ini:
#   [files] section  — local files copied into the image
#   [download] section — URLs fetched at build time and placed in the image
#
# Usage:  creo image                  # build + write tarball
#         creo image -n               # dry-run
#         creo -c image               # clean the tarball

build: go

image: oci
    desc=Build OCI image tarball
    require=build
    tarball=build/image.tar
