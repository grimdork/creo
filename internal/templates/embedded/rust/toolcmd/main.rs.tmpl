use std::env;

fn cmd_serve(args: &[String]) {
    let mut port = 8080u16;
    let mut host = String::from("127.0.0.1");
    let mut i = 0;
    while i < args.len() {
        match args[i].as_str() {
            "-p" | "--port" => {
                i += 1;
                if i < args.len() {
                    port = args[i].parse().unwrap_or(8080);
                }
            }
            "-h" | "--host" => {
                i += 1;
                if i < args.len() {
                    host = args[i].clone();
                }
            }
            _ => {}
        }
        i += 1;
    }
    println!("http://{}:{}", host, port);
}

fn cmd_config(args: &[String]) {
    if args.is_empty() || args[0] == "--show" {
        println!("port=8080\nhost=127.0.0.1");
    } else if args[0] == "--set" && args.len() > 1 {
        println!("set: {}", args[1]);
    } else {
        eprintln!("Usage: $PROJECT config --show|--set key=value");
    }
}

fn cmd_version() {
    println!("$PROJECT v$VERSION");
}

fn main() {
    let args: Vec<String> = env::args().collect();

    if args.len() < 2 {
        eprintln!("Usage: $PROJECT <command> [options]");
        eprintln!("Commands: serve, config, version");
        std::process::exit(1);
    }

    let sub_args: Vec<String> = args[2..].to_vec();

    match args[1].as_str() {
        "serve" => cmd_serve(&sub_args),
        "config" => cmd_config(&sub_args),
        "version" => cmd_version(),
        other => {
            eprintln!("unknown command: {}", other);
            std::process::exit(1);
        }
    }
}
