#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

static int cmd_serve(int argc, char **argv) {
    int port = 8080;
    const char *host = "127.0.0.1";
    int opt;
    while ((opt = getopt(argc, argv, "p:h:")) != -1) {
        switch (opt) {
        case 'p': port = atoi(optarg); break;
        case 'h': host = optarg; break;
        default: return 1;
        }
    }
    printf("http://%s:%d\n", host, port);
    return 0;
}

static int cmd_config(int argc, char **argv) {
    if (argc > 1 && strcmp(argv[1], "--show") == 0) {
        printf("port=8080\nhost=127.0.0.1\n");
    } else if (argc > 2 && strcmp(argv[1], "--set") == 0) {
        printf("set: %s\n", argv[2]);
    } else {
        fprintf(stderr, "Usage: $PROJECT config --show|--set key=value\n");
        return 1;
    }
    return 0;
}

static int cmd_version(void) {
    printf("$PROJECT v$VERSION\n");
    return 0;
}

int main(int argc, char **argv) {
    if (argc < 2) {
        fprintf(stderr, "Usage: $PROJECT <command> [options]\n");
        fprintf(stderr, "Commands: serve, config, version\n");
        return 1;
    }

    if (strcmp(argv[1], "serve") == 0)
        return cmd_serve(argc - 1, argv + 1);
    if (strcmp(argv[1], "config") == 0)
        return cmd_config(argc - 1, argv + 1);
    if (strcmp(argv[1], "version") == 0)
        return cmd_version();

    fprintf(stderr, "unknown command: %s\n", argv[1]);
    return 1;
}
